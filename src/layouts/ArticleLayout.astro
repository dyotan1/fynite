---
import BaseLayout from "./BaseLayout.astro";
import type { Article } from "../utils/articles";
import { formatArticleDate, formatCategory } from "../utils/articles";

interface Props {
  article: Article;
}

const { article } = Astro.props;
const { title, description, category, publishedAt, updatedAt, image, imageAlt } =
  article.data;

const siteUrl = Astro.site ?? new URL("https://fynite.in");
const canonicalPath = Astro.url.pathname;
const articleUrl = new URL(canonicalPath, siteUrl).toString();
const categoryLabel = formatCategory(category);
const categoryHref = `/${category}`;

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description,
  datePublished: publishedAt.toISOString(),
  dateModified: (updatedAt ?? publishedAt).toISOString(),
  ...(image
    ? { image: [new URL(image, siteUrl).toString()] }
    : {}),
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": articleUrl,
  },
  publisher: {
    "@type": "Organization",
    name: "Fynite",
    logo: {
      "@type": "ImageObject",
      url: new URL("/logo.png", siteUrl).toString(),
    },
  },
  articleSection: categoryLabel,
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: siteUrl.toString(),
    },
    {
      "@type": "ListItem",
      position: 2,
      name: categoryLabel,
      item: new URL(categoryHref, siteUrl).toString(),
    },
    {
      "@type": "ListItem",
      position: 3,
      name: title,
      item: articleUrl,
    },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  imageAlt={imageAlt ?? title}
  type="article"
  jsonLd={[articleJsonLd, breadcrumbJsonLd]}
>
  <article class="article">
    <header class="article-header article-container">
      <nav class="article-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <a href={categoryHref}>{categoryLabel}</a>
      </nav>

      <h1>{title}</h1>

      <p class="article-description">{description}</p>

      <div class="article-meta">
        <time datetime={publishedAt.toISOString()}>
          {formatArticleDate(publishedAt)}
        </time>
        {
          updatedAt && (
            <span class="article-updated">
              Updated {formatArticleDate(updatedAt)}
            </span>
          )
        }
      </div>
    </header>

    {
      image && (
        <div class="article-cover page-container">
          <img
            src={image}
            alt={imageAlt ?? ""}
            width="1600"
            height="900"
            loading="eager"
            decoding="async"
          />
        </div>
      )
    }

    <div class="article-body article-container">
      <slot />
    </div>

    <footer class="article-footer article-container">
      <a class="btn btn-secondary" href={categoryHref}>
        More in {categoryLabel}
      </a>
    </footer>
  </article>
</BaseLayout>

<style>
  .article-header {
    padding-top: 40px;
  }

  .article-breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 24px;
    color: var(--color-text-muted);
    font-size: 0.82rem;
    font-weight: 600;
  }

  .article-breadcrumb a:hover {
    color: var(--color-brand);
  }

  h1 {
    font-size: clamp(1.9rem, 4.5vw, 2.75rem);
    line-height: 1.15;
  }

  .article-description {
    margin-top: 18px;
    color: var(--color-text-secondary);
    font-size: 1.1rem;
    line-height: 1.6;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 22px;
    padding-top: 22px;
    border-top: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-size: 0.85rem;
    font-weight: 600;
  }

  .article-cover {
    margin-top: 36px;
  }

  .article-cover img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: var(--radius-md);
  }

  .article-body {
    margin-top: 40px;
    color: var(--color-text);
    font-size: 1.08rem;
    line-height: 1.75;
  }

  .article-body :global(h2) {
    margin-top: 2.2em;
    margin-bottom: 0.6em;
    font-size: 1.45rem;
    line-height: 1.3;
  }

  .article-body :global(h3) {
    margin-top: 1.8em;
    margin-bottom: 0.5em;
    font-size: 1.2rem;
    line-height: 1.35;
  }

  .article-body :global(p) {
    margin-top: 1.2em;
  }

  .article-body :global(p:first-child) {
    margin-top: 0;
  }

  .article-body :global(ul),
  .article-body :global(ol) {
    margin-top: 1.2em;
    padding-left: 1.3em;
  }

  .article-body :global(li) {
    margin-top: 0.5em;
  }

  .article-body :global(a) {
    color: var(--color-brand);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .article-body :global(strong) {
    font-weight: 700;
  }

  .article-body :global(blockquote) {
    margin: 1.6em 0;
    padding-left: 1.1em;
    border-left: 3px solid var(--color-brand);
    color: var(--color-text-secondary);
    font-style: italic;
  }

  .article-footer {
    margin-top: 56px;
    padding-top: 28px;
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 640px) {
    .article-header {
      padding-top: 28px;
    }

    .article-cover {
      margin-top: 26px;
    }

    .article-body {
      margin-top: 30px;
      font-size: 1.02rem;
    }

    .article-footer {
      margin-top: 40px;
    }
  }
</style>
