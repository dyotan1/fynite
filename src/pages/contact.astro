---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact"
  description="Get in touch with Fynite — send a tip, report an error, or ask us to cover something."
  canonical="/contact"
>
  <section class="page-header page-container">
    <p class="eyebrow">Contact</p>
    <h1>Got a tip, a correction, or something we should cover?</h1>
    <p class="page-lede">
      We read everything that comes in. Here's the fastest way to reach us
      depending on what you need.
    </p>
  </section>

  <section class="page-body article-container">
    <div class="contact-grid">
      <div class="contact-card">
        <h2>Story tips</h2>
        <p>
          Seen a meme, trend, or slang term blowing up that we haven't
          covered? Send it over &mdash; a link and a sentence on why it
          caught your eye is all we need.
        </p>
        <a class="contact-link" href="mailto:tips@fynite.in">
          tips@fynite.in
        </a>
      </div>

      <div class="contact-card">
        <h2>Corrections</h2>
        <p>
          If something in a story is wrong or out of date, tell us exactly
          what and where. We fix confirmed errors quickly.
        </p>
        <a class="contact-link" href="mailto:corrections@fynite.in">
          corrections@fynite.in
        </a>
      </div>

      <div class="contact-card">
        <h2>Everything else</h2>
        <p>
          Partnerships, press, or general questions about Fynite &mdash; this
          inbox covers all of it.
        </p>
        <a class="contact-link" href="mailto:hello@fynite.in">
          hello@fynite.in
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding-top: 48px;
    padding-bottom: 40px;
    border-bottom: 1px solid var(--color-border);
  }

  .page-header .eyebrow {
    margin-bottom: 16px;
  }

  h1 {
    max-width: 680px;
    font-size: clamp(1.9rem, 4vw, 2.7rem);
    line-height: 1.15;
  }

  .page-lede {
    max-width: 560px;
    margin-top: 20px;
    color: var(--color-text-secondary);
    font-size: 1.08rem;
    line-height: 1.6;
  }

  .page-body {
    padding-top: 48px;
    padding-bottom: 80px;
  }

  .contact-grid {
    display: grid;
    gap: 20px;
  }

  .contact-card {
    padding: 26px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  .contact-card h2 {
    font-size: 1.1rem;
  }

  .contact-card p {
    margin-top: 10px;
    color: var(--color-text-secondary);
    font-size: 0.96rem;
    line-height: 1.6;
  }

  .contact-link {
    display: inline-block;
    margin-top: 16px;
    color: var(--color-brand);
    font-weight: 700;
    font-size: 0.95rem;
  }

  .contact-link:hover {
    color: var(--color-brand-hover);
  }

  @media (max-width: 640px) {
    .page-header {
      padding-top: 36px;
      padding-bottom: 32px;
    }

    .page-body {
      padding-top: 36px;
      padding-bottom: 56px;
    }
  }
</style>
