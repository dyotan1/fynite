---
import BaseLayout from "../layouts/BaseLayout.astro";
import ArticleCard from "../components/ArticleCard.astro";

import { getLatestArticles, getTrendingArticles } from "../utils/articles";

const trendingArticles = await getTrendingArticles(4);
const latestArticles = await getLatestArticles(9);

const trendingIds = new Set(trendingArticles.map((article) => article.id));

const latestWithoutTrending = latestArticles.filter(
  (article) => !trendingIds.has(article.id),
);

const hasTrending = trendingArticles.length > 0;
const hasLatest = latestWithoutTrending.length > 0;
const hasAnyArticles = hasTrending || hasLatest;
---

<BaseLayout>
  <section class="intro">
    <div class="intro-inner page-container">
      <p class="eyebrow">The internet, explained</p>

      <h1>
        What's happening online, and why everyone's talking about it.
      </h1>

      <p class="intro-description">
        Fynite breaks down the memes, slang, and viral moments taking over
        your feed &mdash; where they came from, what they mean, and why they
        caught on.
      </p>
    </div>
  </section>

  {
    hasTrending && (
      <section
        class="content-section page-container"
        aria-labelledby="trending-heading"
      >
        <div class="section-heading">
          <h2 id="trending-heading">Trending now</h2>
          <a class="section-link" href="/viral">
            See all trending
          </a>
        </div>

        <div class="trending-grid">
          {trendingArticles.map((article, index) => (
            <ArticleCard article={article} featured={index === 0} />
          ))}
        </div>
      </section>
    )
  }

  {
    hasLatest && (
      <section
        class="content-section page-container"
        aria-labelledby="latest-heading"
      >
        <div class="section-heading">
          <h2 id="latest-heading">Latest stories</h2>
        </div>

        <div class="latest-grid">
          {latestWithoutTrending.map((article) => (
            <ArticleCard article={article} />
          ))}
        </div>
      </section>
    )
  }

  {
    !hasAnyArticles && (
      <section class="content-section page-container">
        <div class="empty-state">
          <p class="eyebrow">Coming soon</p>
          <h2>The first stories are on the way.</h2>
          <p>
            We're writing our first explainers right now. Check back shortly
            for the internet culture stories worth knowing about.
          </p>
        </div>
      </section>
    )
  }
</BaseLayout>

<style>
  .intro {
    padding-top: 56px;
    padding-bottom: 48px;
    border-bottom: 1px solid var(--color-border);
  }

  .intro .eyebrow {
    margin-bottom: 18px;
  }

  h1 {
    max-width: 780px;
    font-size: clamp(1.9rem, 4vw, 3rem);
    line-height: 1.15;
  }

  .intro-description {
    max-width: 560px;
    margin-top: 20px;
    color: var(--color-text-secondary);
    font-size: 1.05rem;
    line-height: 1.6;
  }

  .content-section {
    padding-top: 64px;
  }

  .section-heading {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 32px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--color-border);
  }

  .section-heading h2 {
    font-size: clamp(1.4rem, 2.4vw, 1.9rem);
  }

  .section-link {
    flex: 0 0 auto;
    color: var(--color-brand);
    font-size: 0.85rem;
    font-weight: 700;
  }

  .section-link:hover {
    color: var(--color-brand-hover);
  }

  .trending-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 44px 32px;
  }

  .trending-grid > :first-child {
    grid-column: 1 / -1;
  }

  .latest-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 44px 28px;
  }

  .empty-state {
    max-width: 520px;
    padding: 56px 0;
  }

  .empty-state h2 {
    margin-top: 14px;
    font-size: clamp(1.4rem, 3vw, 1.9rem);
  }

  .empty-state p:last-child {
    margin-top: 14px;
    color: var(--color-text-secondary);
    font-size: 1rem;
    line-height: 1.6;
  }

  @media (max-width: 820px) {
    .latest-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .intro {
      padding-top: 40px;
      padding-bottom: 36px;
    }

    .content-section {
      padding-top: 48px;
    }

    .section-heading {
      margin-bottom: 24px;
    }

    .trending-grid,
    .latest-grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    .trending-grid > :first-child {
      grid-column: auto;
    }
  }
</style>