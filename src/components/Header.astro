---
import SearchButton from "./SearchButton.astro";

const navItems = [
  { href: "/", label: "Home" },
  { href: "/memes", label: "Memes" },
  { href: "/viral", label: "Viral" },
  { href: "/slang", label: "Slang" },
  { href: "/explained", label: "Explained" },
  { href: "/about", label: "About" },
];

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<header class="site-header">
  <div class="header-inner page-container">
    <a class="brand" href="/" aria-label="Fynite home">
      <img
        class="brand-logo"
        src="/logo.png"
        alt=""
        width="34"
        height="34"
      />

      <span class="brand-name">Fynite</span>
    </a>

    <div class="header-actions">
      <SearchButton />

      <button
        class="menu-button"
        type="button"
        aria-label="Open navigation"
        aria-expanded="false"
        aria-controls="site-navigation"
        data-menu-button
      >
        <svg
          viewBox="0 0 24 24"
          aria-hidden="true"
          width="22"
          height="22"
        >
          <path d="M4 7h16" />
          <path d="M4 12h16" />
          <path d="M4 17h16" />
        </svg>
      </button>
    </div>
  </div>

  <nav
    class="site-navigation"
    id="site-navigation"
    aria-label="Main navigation"
    data-navigation
    hidden
  >
    <div class="navigation-inner page-container">
      {
        navItems.map((item) => {
          const itemPath = item.href.replace(/\/$/, "") || "/";
          const isCurrent = itemPath === currentPath;
          return (
            <a href={item.href} aria-current={isCurrent ? "page" : undefined}>
              {item.label}
            </a>
          );
        })
      }
    </div>
  </nav>
</header>

<script>
  const menuButton =
    document.querySelector<HTMLButtonElement>("[data-menu-button]");

  const navigation =
    document.querySelector<HTMLElement>("[data-navigation]");

  if (menuButton && navigation) {
    menuButton.addEventListener("click", () => {
      const isOpen =
        menuButton.getAttribute("aria-expanded") === "true";

      menuButton.setAttribute(
        "aria-expanded",
        String(!isOpen)
      );

      menuButton.setAttribute(
        "aria-label",
        isOpen ? "Open navigation" : "Close navigation"
      );

      navigation.hidden = isOpen;
    });

    const mediaQuery = window.matchMedia("(min-width: 760px)");

    const syncForViewport = () => {
      if (mediaQuery.matches) {
        navigation.hidden = false;
      } else {
        navigation.hidden = true;
        menuButton.setAttribute("aria-expanded", "false");
        menuButton.setAttribute("aria-label", "Open navigation");
      }
    };

    syncForViewport();
    mediaQuery.addEventListener("change", syncForViewport);
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--color-bg);
  }

  .header-inner {
    height: var(--header-height);
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--color-border);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
  }

  .brand-logo {
    width: 34px;
    height: 34px;
    flex: 0 0 auto;
    object-fit: contain;
  }

  .brand-name {
    font-size: 1.05rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .menu-button {
    width: 42px;
    height: 42px;
    display: grid;
    place-items: center;
    flex: 0 0 auto;
    color: var(--color-text);
    background: transparent;
    border-radius: var(--radius-round);
  }

  .menu-button svg {
    fill: none;
    stroke: currentColor;
    stroke-width: 1.8;
    stroke-linecap: round;
  }

  .menu-button:active {
    transform: scale(0.94);
  }

  .site-navigation {
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg);
  }

  .navigation-inner {
    display: flex;
    flex-direction: column;
    padding-top: 10px;
    padding-bottom: 14px;
  }

  .navigation-inner a {
    padding: 12px 0;
    color: var(--color-text-secondary);
    font-size: 1rem;
    font-weight: 600;
  }

  .navigation-inner a[aria-current="page"] {
    color: var(--color-brand);
  }

  @media (hover: hover) {
    .menu-button:hover {
      color: var(--color-brand);
      background: var(--color-brand-soft);
    }

    .navigation-inner a:hover {
      color: var(--color-brand);
    }
  }

  @media (min-width: 760px) {
    .menu-button {
      display: none;
    }

    .navigation-inner {
      flex-direction: row;
      align-items: center;
      gap: 28px;
      padding-top: 0;
      padding-bottom: 0;
    }

    .navigation-inner a {
      padding: 0;
      font-size: 0.9rem;
    }

    .site-navigation {
      border-bottom: none;
    }

    .header-inner {
      border-bottom: none;
    }

    .site-header {
      border-bottom: 1px solid var(--color-border);
    }
  }
</style>
