---
import type { Article } from "../utils/articles";
import {
  formatArticleDate,
  formatCategory,
  getArticleUrl,
} from "../utils/articles";

interface Props {
  article: Article;
  featured?: boolean;
}

const { article, featured = false } = Astro.props;

const { title, description, category, publishedAt, image, imageAlt } =
  article.data;

const href = getArticleUrl(article);
---

<article
  class:list={["article-card", { "article-card--featured": featured }]}
>
  <a class="article-link" href={href}>
    <div class="article-image">
      {
        image ? (
          <img
            src={image}
            alt={imageAlt ?? ""}
            loading={featured ? "eager" : "lazy"}
            decoding="async"
            width="800"
            height="500"
          />
        ) : (
          <span class="article-image-fallback" aria-hidden="true">
            {formatCategory(category)}
          </span>
        )
      }
    </div>

    <div class="article-content">
      <div class="article-meta">
        <span class="article-category">{formatCategory(category)}</span>
        <span aria-hidden="true">&middot;</span>
        <time datetime={publishedAt.toISOString()}>
          {formatArticleDate(publishedAt)}
        </time>
      </div>

      <h3>{title}</h3>

      <p>{description}</p>
    </div>
  </a>
</article>

<style>
  .article-card {
    min-width: 0;
  }

  .article-link {
    display: block;
  }

  .article-image {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    margin-bottom: 18px;
    background: var(--color-surface);
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius-md);
  }

  .article-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 320ms var(--ease-standard);
  }

  .article-image-fallback {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    color: var(--color-brand);
    background: var(--color-brand-soft);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .article-content {
    min-width: 0;
  }

  .article-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 7px;
    margin-bottom: 10px;
    color: var(--color-text-muted);
    font-size: 0.75rem;
    font-weight: 600;
  }

  .article-category {
    color: var(--color-brand);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  h3 {
    font-size: clamp(1.15rem, 1.6vw, 1.4rem);
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.01em;
  }

  p {
    margin-top: 10px;
    color: var(--color-text-secondary);
    font-size: 0.92rem;
    line-height: 1.55;

    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-card--featured h3 {
    font-size: clamp(1.5rem, 2.6vw, 2.1rem);
    line-height: 1.15;
  }

  .article-card--featured p {
    max-width: 640px;
    font-size: 1rem;
    -webkit-line-clamp: 3;
  }

  @media (hover: hover) {
    .article-link:hover h3 {
      color: var(--color-brand);
    }

    .article-link:hover .article-image img {
      transform: scale(1.03);
    }
  }

  @media (max-width: 640px) {
    .article-image {
      margin-bottom: 14px;
      border-radius: var(--radius-sm);
    }

    .article-card--featured h3 {
      font-size: 1.5rem;
    }
  }
</style>
