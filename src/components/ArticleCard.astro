---
import type { Article } from "../utils/articles";
import {
  formatArticleDate,
  formatCategory,
  getArticleUrl,
} from "../utils/articles";

interface Props {
  article: Article;
  featured?: boolean;
}

const {
  article,
  featured = false,
} = Astro.props;

const {
  title,
  description,
  category,
  publishedAt,
  image,
  imageAlt,
} = article.data;

const href = getArticleUrl(article);
---

<article
  class:list={[
    "article-card",
    { "article-card--featured": featured },
  ]}
>
  <a class="article-link" href={href}>
    {
      image && (
        <div class="article-image">
          <img
            src={image}
            alt={imageAlt ?? ""}
            loading={featured ? "eager" : "lazy"}
            decoding="async"
          />
        </div>
      )
    }

    <div class="article-content">
      <div class="article-meta">
        <span class="article-category">
          {formatCategory(category)}
        </span>

        <span aria-hidden="true">·</span>

        <time datetime={publishedAt.toISOString()}>
          {formatArticleDate(publishedAt)}
        </time>
      </div>

      <h3>{title}</h3>

      <p>{description}</p>
    </div>
  </a>
</article>

<style>
  .article-card {
    min-width: 0;
  }

  .article-link {
    display: block;
  }

  .article-image {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    margin-bottom: 20px;
    background: var(--color-surface);
    border-radius: var(--radius-md);
  }

  .article-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 320ms var(--ease-standard);
  }

  .article-content {
    min-width: 0;
  }

  .article-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 7px;
    margin-bottom: 12px;
    color: var(--color-text-muted);
    font-size: 0.75rem;
    font-weight: 600;
  }

  .article-category {
    color: var(--color-brand);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
  }

  h3 {
    font-size: clamp(1.35rem, 2vw, 1.8rem);
    font-weight: 800;
    line-height: 1.08;
  }

  p {
    margin-top: 12px;
    color: var(--color-text-secondary);
    font-size: 0.94rem;
    line-height: 1.6;
  }

  .article-card--featured h3 {
    font-size: clamp(2rem, 4vw, 3.6rem);
    line-height: 0.98;
  }

  .article-card--featured p {
    max-width: 680px;
    font-size: 1rem;
  }

  @media (hover: hover) {
    .article-link:hover h3 {
      color: var(--color-brand);
    }

    .article-link:hover .article-image img {
      transform: scale(1.015);
    }
  }

  @media (max-width: 640px) {
    .article-image {
      margin-bottom: 16px;
      border-radius: var(--radius-sm);
    }

    .article-card--featured h3 {
      font-size: 2rem;
    }
  }
</style>