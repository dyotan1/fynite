---
import BaseLayout from "../layouts/BaseLayout.astro";
import ArticleCard from "./ArticleCard.astro";
import { getPublishedArticles } from "../utils/articles";
import type { Article } from "../utils/articles";

interface Props {
  category: Article["data"]["category"];
  title: string;
  description: string;
}

const { category, title, description } = Astro.props;

const allArticles = await getPublishedArticles();
const articles = allArticles.filter((article) => article.data.category === category);
---

<BaseLayout
  title={title}
  description={description}
  canonical={`/${category}`}
>
  <section class="archive-header page-container">
    <p class="eyebrow">Category</p>
    <h1>{title}</h1>
    <p class="archive-description">{description}</p>
  </section>

  <section class="archive-body page-container">
    {
      articles.length > 0 ? (
        <div class="archive-grid">
          {articles.map((article) => (
            <ArticleCard article={article} />
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <p>
            No {title.toLowerCase()} stories yet &mdash; we're working on it.
            Check back soon, or explore what's trending on the homepage.
          </p>
          <a class="btn btn-secondary" href="/">
            Back to home
          </a>
        </div>
      )
    }
  </section>
</BaseLayout>

<style>
  .archive-header {
    padding-top: 48px;
    padding-bottom: 40px;
    border-bottom: 1px solid var(--color-border);
  }

  .archive-header .eyebrow {
    margin-bottom: 16px;
  }

  h1 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
  }

  .archive-description {
    max-width: 560px;
    margin-top: 16px;
    color: var(--color-text-secondary);
    font-size: 1.02rem;
    line-height: 1.6;
  }

  .archive-body {
    padding-top: 48px;
    padding-bottom: 80px;
  }

  .archive-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 44px 28px;
  }

  .empty-state {
    max-width: 480px;
    padding: 40px 0 8px;
  }

  .empty-state p {
    color: var(--color-text-secondary);
    font-size: 1rem;
    line-height: 1.6;
  }

  .empty-state .btn {
    margin-top: 22px;
  }

  @media (max-width: 820px) {
    .archive-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .archive-header {
      padding-top: 36px;
      padding-bottom: 32px;
    }

    .archive-body {
      padding-top: 36px;
      padding-bottom: 56px;
    }

    .archive-grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }
  }
</style>
