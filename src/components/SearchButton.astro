---
import {
  formatCategory,
  getArticleUrl,
  getPublishedArticles,
} from "../utils/articles";

const articles = await getPublishedArticles();

const searchIndex = articles.map((article) => ({
  title: article.data.title,
  description: article.data.description,
  category: formatCategory(article.data.category),
  url: getArticleUrl(article),
}));
---

<button
  class="search-button"
  type="button"
  aria-label="Search Fynite"
  aria-haspopup="dialog"
  data-search-button
>
  <svg
    viewBox="0 0 24 24"
    aria-hidden="true"
    width="22"
    height="22"
  >
    <circle cx="10.8" cy="10.8" r="6.6" />
    <path d="m16 16 4.2 4.2" />
  </svg>
</button>

<dialog
  class="search-dialog"
  aria-labelledby="search-title"
  data-search-dialog
>
  <div class="search-panel">
    <div class="search-header">
      <div>
        <p class="search-eyebrow">Search</p>
        <h2 id="search-title">Find an explanation</h2>
      </div>

      <button
        class="search-close"
        type="button"
        aria-label="Close search"
        data-search-close
      >
        &times;
      </button>
    </div>

    <label class="search-field">
      <span class="sr-only">Search articles</span>

      <svg
        viewBox="0 0 24 24"
        aria-hidden="true"
        width="20"
        height="20"
      >
        <circle cx="10.8" cy="10.8" r="6.6" />
        <path d="m16 16 4.2 4.2" />
      </svg>

      <input
        type="search"
        placeholder="Search memes, slang, trends..."
        autocomplete="off"
        data-search-input
      />
    </label>

    <p
      class="search-status"
      aria-live="polite"
      data-search-status
    >
      Start typing to search Fynite.
    </p>

    <div
      class="search-results"
      data-search-results
    ></div>
  </div>
</dialog>

<script define:vars={{ searchIndex }}>
  const button = document.querySelector("[data-search-button]");
  const dialog = document.querySelector("[data-search-dialog]");
  const closeButton = document.querySelector("[data-search-close]");
  const input = document.querySelector("[data-search-input]");
  const results = document.querySelector("[data-search-results]");
  const status = document.querySelector("[data-search-status]");

  const escapeHtml = (value) =>
    value.replace(
      /[&<>'"]/g,
      (character) =>
        ({
          "&": "&amp;",
          "<": "&lt;",
          ">": "&gt;",
          "'": "&#39;",
          '"': "&quot;",
        })[character],
    );

  const renderResults = () => {
    const query = input.value.trim().toLowerCase();

    results.innerHTML = "";

    if (!query) {
      status.textContent = "Start typing to search Fynite.";
      return;
    }

    const matches = searchIndex.filter((article) =>
      `${article.title} ${article.description} ${article.category}`
        .toLowerCase()
        .includes(query),
    );

    status.textContent = matches.length
      ? `${matches.length} ${
          matches.length === 1 ? "result" : "results"
        } found.`
      : `No results for “${input.value.trim()}”.`;

    results.innerHTML = matches
      .map(
        (article) => `
          <a class="search-result" href="${article.url}">
            <span class="search-result-category">
              ${escapeHtml(article.category)}
            </span>

            <strong>
              ${escapeHtml(article.title)}
            </strong>

            <span class="search-result-description">
              ${escapeHtml(article.description)}
            </span>
          </a>
        `,
      )
      .join("");
  };

  button?.addEventListener("click", () => {
    dialog.showModal();

    requestAnimationFrame(() => {
      input.focus();
    });
  });

  closeButton?.addEventListener("click", () => {
    dialog.close();
  });

  input?.addEventListener("input", renderResults);

  dialog?.addEventListener("click", (event) => {
    if (event.target === dialog) {
      dialog.close();
    }
  });

  dialog?.addEventListener("close", () => {
    input.value = "";
    results.innerHTML = "";
    status.textContent = "Start typing to search Fynite.";
    button?.focus();
  });
</script>

<style>
  .search-button,
  .search-close {
    display: grid;
    place-items: center;
    color: var(--color-text);
    background: transparent;
    border-radius: var(--radius-round);
  }

  .search-button {
    width: 44px;
    height: 44px;
    flex: 0 0 auto;
  }

  .search-button svg,
  .search-field svg {
    fill: none;
    stroke: currentColor;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .search-button:active {
    transform: scale(0.94);
  }

  .search-dialog {
    width: min(680px, calc(100% - 28px));
    max-height: min(720px, calc(100dvh - 40px));
    padding: 0;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg);
    color: var(--color-text);
    box-shadow: 0 24px 80px rgb(0 0 0 / 0.18);
  }

  .search-dialog::backdrop {
    background: rgb(20 18 19 / 0.48);
    backdrop-filter: blur(3px);
  }

  .search-panel {
    padding: 28px;
  }

  .search-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 20px;
  }

  .search-eyebrow {
    margin-bottom: 5px;
    color: var(--color-brand);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .search-header h2 {
    font-size: clamp(1.35rem, 3vw, 1.8rem);
    line-height: 1.2;
  }

  .search-close {
    width: 40px;
    height: 40px;
    flex: 0 0 auto;
    font-size: 1.8rem;
    line-height: 1;
  }

  .search-field {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 24px;
    padding: 0 16px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    color: var(--color-text-muted);
  }

  .search-field:focus-within {
    border-color: var(--color-brand);
    box-shadow: 0 0 0 3px var(--color-brand-soft);
  }

  .search-field input {
    width: 100%;
    min-width: 0;
    padding: 15px 0;
    border: 0;
    outline: 0;
    background: transparent;
    color: var(--color-text);
    font: inherit;
  }

  .search-field input::placeholder {
    color: var(--color-text-muted);
  }

  .search-status {
    margin: 16px 0 8px;
    color: var(--color-text-muted);
    font-size: 0.82rem;
  }

  .search-results {
    display: grid;
    max-height: 430px;
    overflow-y: auto;
  }

  :global(.search-result) {
    display: grid;
    gap: 5px;
    padding: 16px 4px;
    border-bottom: 1px solid var(--color-border-soft);
  }

  :global(.search-result-category) {
    color: var(--color-brand);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  :global(.search-result strong) {
    font-size: 1rem;
    line-height: 1.35;
  }

  :global(.search-result-description) {
    color: var(--color-text-secondary);
    font-size: 0.86rem;
    line-height: 1.5;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (hover: hover) {
    .search-button:hover,
    .search-close:hover {
      background: var(--color-brand-soft);
      color: var(--color-brand);
    }

    :global(.search-result:hover) strong {
      color: var(--color-brand);
    }
  }

  @media (max-width: 640px) {
    .search-dialog {
      width: 100%;
      max-width: none;
      max-height: 88dvh;
      margin: auto 0 0;
      border-radius:
        var(--radius-md)
        var(--radius-md)
        0
        0;
      border-left: 0;
      border-right: 0;
      border-bottom: 0;
    }

    .search-panel {
      padding: 22px 18px 28px;
    }

    .search-results {
      max-height: 52dvh;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .search-button:active {
      transform: none;
    }
  }
</style>