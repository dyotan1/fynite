---
const currentYear = new Date().getFullYear();

const exploreLinks = [
  { href: "/memes", label: "Memes" },
  { href: "/viral", label: "Viral" },
  { href: "/slang", label: "Slang" },
  { href: "/explained", label: "Explained" },
];

const siteLinks = [
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
  { href: "/privacy", label: "Privacy" },
];
---

<footer class="site-footer">
  <div class="footer-inner page-container">
    <div class="footer-main">
      <div class="footer-brand">
        <a href="/" class="brand" aria-label="Fynite home">
          <img src="/favicon.png" alt="" width="32" height="32" />
          <span>Fynite</span>
        </a>

        <p>The internet, explained.</p>
      </div>

      <div class="footer-columns">
        <nav class="footer-nav" aria-label="Explore categories">
          <p class="footer-nav-heading">Explore</p>
          {exploreLinks.map((link) => (
            <a href={link.href}>{link.label}</a>
          ))}
        </nav>

        <nav class="footer-nav" aria-label="Site">
          <p class="footer-nav-heading">Site</p>
          {siteLinks.map((link) => (
            <a href={link.href}>{link.label}</a>
          ))}
        </nav>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {currentYear} Fynite. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 96px;
  }

  .footer-inner {
    padding-top: 40px;
    padding-bottom: 28px;
    border-top: 1px solid var(--color-border);
  }

  .footer-main {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 48px;
  }

  .footer-brand .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }

  .footer-brand img {
    width: 32px;
    height: 32px;
    object-fit: contain;
  }

  .footer-brand .brand span {
    font-size: 1.05rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .footer-brand p {
    margin-top: 14px;
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .footer-columns {
    display: flex;
    gap: 56px;
  }

  .footer-nav-heading {
    margin-bottom: 14px;
    color: var(--color-text-muted);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 11px;
  }

  .footer-nav a {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    font-weight: 600;
  }

  .footer-bottom {
    margin-top: 48px;
    padding-top: 20px;
    border-top: 1px solid var(--color-border-soft);
  }

  .footer-bottom p {
    color: var(--color-text-muted);
    font-size: 0.78rem;
    line-height: 1.5;
  }

  @media (hover: hover) {
    .footer-nav a:hover {
      color: var(--color-brand);
    }
  }

  @media (max-width: 640px) {
    .site-footer {
      margin-top: 72px;
    }

    .footer-main {
      flex-direction: column;
      gap: 32px;
    }

    .footer-columns {
      gap: 36px;
    }

    .footer-bottom {
      margin-top: 36px;
    }
  }
</style>
